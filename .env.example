# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — the pipeline will not start without these
# ─────────────────────────────────────────────────────────────────────────────

# Claude API  →  https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Tavily (web search for research agent)  →  https://app.tavily.com
TAVILY_API_KEY=tvly-...

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — features degrade gracefully when these are absent
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI DALL-E 3 (image generation)  →  https://platform.openai.com/api-keys
# If absent: image_url is set to null and posts skip visuals
OPENAI_API_KEY=sk-...

# Slack (notifications + marketing team bot)  →  https://api.slack.com/apps
# Scopes needed: chat:write, files:write, app_mentions:read, im:read, im:write
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C0XXXXXXXXX          # #content-published channel ID
# App-level token for Socket Mode bot (python main.py slack-bot)
# Create at: Basic Information → App-Level Tokens → scope: connections:write
SLACK_APP_TOKEN=xapp-...
# Signing secret for HTTP webhook mode (POST /slack/events)
SLACK_SIGNING_SECRET=...

# Apify (Twitter/X trend scraping)  →  https://console.apify.com/account/integrations
# If absent: Twitter trends skipped; other sources still run
APIFY_API_TOKEN=apify_api_...

# Reddit API (viral community signals — r/india, r/bollywood, r/Cricket etc.)
# Create app at https://www.reddit.com/prefs/apps → "script" type, read-only
# If absent: Reddit source skipped
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
# REDDIT_USER_AGENT is set automatically; override only if needed
# REDDIT_USER_AGENT=housing-marketeer/1.0 (by /u/yourhandle)

# X / Twitter (for publishing tweets)  →  https://developer.twitter.com/en/portal
# Needs Read+Write permissions. If absent: Twitter posts saved to output/ only.
TWITTER_API_KEY=...
TWITTER_API_SECRET=...
TWITTER_ACCESS_TOKEN=...
TWITTER_ACCESS_TOKEN_SECRET=...
TWITTER_BEARER_TOKEN=...

# Instagram Graph API  →  https://developers.facebook.com/apps/
# Needs instagram_basic + instagram_content_publish permissions
# If absent: Instagram posts saved to output/ only.
INSTAGRAM_ACCESS_TOKEN=...
INSTAGRAM_ACCOUNT_ID=...             # numeric Instagram Business Account ID

# YouTube Data API v3  →  https://console.cloud.google.com/
# Enable "YouTube Data API v3"; create an API key (for read/trend research)
# YOUTUBE_API_KEY alone enables trend research (trending videos India).
# YOUTUBE_CHANNEL_ID additionally enables publishing. Both are optional.
YOUTUBE_API_KEY=AIza...
YOUTUBE_CHANNEL_ID=UC...

# Housing.com internal CMS API (stub until real API is available)
HOUSING_CMS_API_KEY=...
HOUSING_CMS_BASE_URL=https://cms.housing.com/api/v1

# ─────────────────────────────────────────────────────────────────────────────
# INFRASTRUCTURE (defaults work for local; change for production)
# ─────────────────────────────────────────────────────────────────────────────

# SQLite by default (no setup needed). For Postgres: postgresql+asyncpg://user:pass@host/db
DATABASE_URL=sqlite+aiosqlite:///./housing_content.db

# Set to "true" to skip all social media posting (writes to output/ instead)
DRY_RUN=true

# How many content ideas the creative agent generates per run (top N are used)
MAX_CREATIVE_DRAFTS=3

# Which platforms to target (comma-separated). All 4 by default.
TARGET_PLATFORMS=twitter,instagram,youtube,housing_news

# Max QA retry attempts before a post is dropped
MAX_QA_RETRIES=1

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
